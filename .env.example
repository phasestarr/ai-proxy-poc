AI_PROXY_CONTAINER_NAME=ai-proxy-frontend

# Purpose:
# - Provide example environment variables for Docker Compose based execution.
#
# Should include:
# - PostgreSQL database name, user, password, and port
# - Backend port and environment mode
# - Frontend receive port for the upstream TLS terminator
#
# Notes:
# - This file is a template only.
# - Real secrets must go into a local .env file that is not committed.
# - Docker Compose uses the repo-root .env file for variable expansion.
# - The version markers below drive the current image tags and build args.

POSTGRES_DB=$your_postgres_db
POSTGRES_USER=$your_postgres_user
POSTGRES_PASSWORD=$your_postgres_password
APP_NAME=AI Proxy API
APP_ENV=dev
AUTH_COOKIE_SECURE=true
# Replace before running Compose:
# - Set GOOGLE_CLOUD_PROJECT to your GCP project ID.
# - Ensure the credentials file exists under secrets/ or update the path below.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=$your_gcp_project_id
GOOGLE_CLOUD_LOCATION=$your_gcp_project_location
VERTEX_AI_MODEL=$your_google_genai_model
VERTEX_AI_API_VERSION=v1
# Optional: comma-separated corpus resource names like
# projects/$your_gcp_project_id/locations/$your_gcp_project_location/ragCorpora/$your_rag_corpus_id
VERTEX_AI_RAG_CORPORA=
VERTEX_AI_RAG_SIMILARITY_TOP_K=5
VERTEX_AI_RAG_VECTOR_DISTANCE_THRESHOLD=
CHAT_INFLIGHT_LOCK_TTL_SECONDS=180
CHAT_RATE_LIMIT_PER_MINUTE=10
CHAT_RATE_LIMIT_PER_HOUR=30
STARTUP_DEPENDENCY_MAX_ATTEMPTS=30
STARTUP_DEPENDENCY_RETRY_SECONDS=2

PYTHON_VERSION=3.13.12
PIP_VERSION=25.3
NODE_VERSION=24.14.0
NPM_VERSION=11.9.0
POSTGRES_VERSION=16-alpine
NGINX_VERSION=1.27-alpine
REDIS_VERSION=7-alpine
