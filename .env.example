AI_PROXY_CONTAINER_NAME=ai-proxy-frontend

POSTGRES_DB=ai_proxy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

APP_NAME=AI Proxy API
APP_ENV=dev
AUTH_COOKIE_SECURE=true
AUTH_DATA_ENCRYPTION_KEY=$your-fernet-key

GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=$your-gcp-project-id
VERTEX_AI_API_VERSION=v1
VERTEX_AI_RAG_CORPORA=$your-vertex-ai-corpora
VERTEX_AI_RAG_SIMILARITY_TOP_K=5
VERTEX_AI_RAG_VECTOR_DISTANCE_THRESHOLD=

CHAT_INFLIGHT_LOCK_TTL_SECONDS=180
CHAT_RATE_LIMIT_PER_MINUTE=10
CHAT_RATE_LIMIT_PER_HOUR=30
STARTUP_DEPENDENCY_MAX_ATTEMPTS=30
STARTUP_DEPENDENCY_RETRY_SECONDS=2

MICROSOFT_CLIENT_ID=$your-microsoft-entra-app-id
MICROSOFT_CLIENT_SECRET=$your-microsoft-client-secret-key
MICROSOFT_AUTHORITY=$your-microsoft-entra-app-authority
MICROSOFT_REDIRECT_PATH=/api/v1/auth/callback/microsoft
MICROSOFT_OAUTH_TRANSACTION_MINUTES=10

PYTHON_VERSION=3.13.12
PIP_VERSION=25.3
NODE_VERSION=24.14.0
NPM_VERSION=11.9.0
POSTGRES_VERSION=16-alpine
NGINX_VERSION=1.27-alpine
REDIS_VERSION=7-alpine
