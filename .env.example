AI_PROXY_CONTAINER_NAME=ai-proxy-frontend

POSTGRES_DB=ai_proxy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

APP_NAME=AI Proxy API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
AUTH_SESSION_COOKIE_NAME=session_id
AUTH_CONFLICT_COOKIE_NAME=session_conflict_id
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict
AUTH_COOKIE_PATH=/
AUTH_COOKIE_DOMAIN=
AUTH_DATA_ENCRYPTION_KEY=$your-fernet-key
AUTH_GUEST_IDLE_MINUTES=360
AUTH_GUEST_ABSOLUTE_HOURS=24
AUTH_GUEST_MAX_SESSIONS=2
AUTH_MICROSOFT_IDLE_MINUTES=1440
AUTH_MICROSOFT_ABSOLUTE_DAYS=1
AUTH_MICROSOFT_MAX_SESSIONS=4
AUTH_SESSION_LIMIT_STRATEGY=reject
AUTH_CONFLICT_TICKET_MINUTES=5
AUTH_CLEANUP_INTERVAL_MINUTES=60

ANTHROPIC_API_KEY=$your-anthropic-api-key
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_WEB_SEARCH_MAX_USES=5
ANTHROPIC_WEB_SEARCH_ALLOWED_DOMAINS=
ANTHROPIC_WEB_SEARCH_BLOCKED_DOMAINS=

OPENAI_API_KEY=$your-openai-api-key
OPENAI_VECTOR_STORE_IDS=$your-openai-vector-store-ids
OPENAI_FILE_SEARCH_MAX_NUM_RESULTS=5
OPENAI_FILE_SEARCH_SCORE_THRESHOLD=
OPENAI_CODE_INTERPRETER_MEMORY_LIMIT=4g

GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=$your-gcp-project-id
VERTEX_AI_API_VERSION=v1
VERTEX_AI_RAG_CORPORA=$your-vertex-ai-corpora
VERTEX_AI_RAG_SIMILARITY_TOP_K=5
VERTEX_AI_RAG_VECTOR_DISTANCE_THRESHOLD=

CHAT_INFLIGHT_LOCK_TTL_SECONDS=180
CHAT_RATE_LIMIT_PER_MINUTE=10
CHAT_RATE_LIMIT_PER_HOUR=30
STARTUP_DEPENDENCY_MAX_ATTEMPTS=30
STARTUP_DEPENDENCY_RETRY_SECONDS=2

MICROSOFT_CLIENT_ID=$your-microsoft-entra-app-id
MICROSOFT_CLIENT_SECRET=$your-microsoft-client-secret-key
MICROSOFT_AUTHORITY=$your-microsoft-entra-app-authority
MICROSOFT_REDIRECT_PATH=/api/v1/auth/callback/microsoft
MICROSOFT_OAUTH_TRANSACTION_MINUTES=10
MICROSOFT_SCOPES=["email"]

PYTHON_VERSION=3.13.12
PIP_VERSION=25.3
NODE_VERSION=24.14.0
NPM_VERSION=11.9.0
POSTGRES_VERSION=16-alpine
NGINX_VERSION=1.27-alpine
REDIS_VERSION=7-alpine
